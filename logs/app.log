2025-08-08 11:56:25,952 - EduRAG - INFO - MySQL 答案: import time
import contextlib


@contextlib.contextmanager
def timing():
    start = time.time()
    yield None
    end = time.time()
    print("函数执行时间是%d毫秒" % (end - start))


def func(number):
    li = [1, 2, 4]
    if number < 4:
        return li[number - 1]
    else:
        if number > 3:
            return func(number - 1) + func(number - 2) + func(number - 3)


with timing():
    print(func(30))
